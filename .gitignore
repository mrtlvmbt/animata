# Build artifacts
/target
# v2 is a standalone nested workspace — ignore its build dir too
/v2/target
# R-1 (#219): v2/crates/render is its OWN standalone workspace (excluded from v2/Cargo.toml), so its
# build dir is a separate path `/v2/target` does not cover.
/v2/crates/render/target

# OS junk
.DS_Store

# Local Claude settings
.claude/settings.local.json

# no-local-sim guard runtime artifacts (bypass token + audit log)
.claude/.sim-allow
.claude/no-local-sim.log

# Generated simulation outputs (saves, stat/tree dumps, sweeps)
/animata-save.bin
/animata_save.txt
/animata_save.txt.tree
/animata_stats.csv
/animata_tree.csv
/sweep.csv

# Dev-bridge screenshots
/*.png

# Dev-bridge live port (per-worktree, written at startup)
/.animata-dev-port

# CodeGraph local index
/.codegraph/

# Agent metrics (local run log, machine-specific)
/tools/agent-metrics/runs.tsv

# Quick-save artifact (F5/F9)
animata-save.bin

# CI feedback report (scripts/ci-report.sh runtime output)
/.ci-report/

# sim-run.sh fetched artifacts
/.sim-run/

# ci-report.sh redirect target (local)
/.ci-report-run.log

# kit-critic launcher-managed plan snapshots (auto-delta baselines) — transient, machine-local
.claude/.consensus/
